# 最小 provider 能力级优先级模板
# 说明：
# 1. 本文件只维护 provider 选择相关示例，其他本地开发配置请参考 .env
# 2. preferredProvider 始终具有最高优先级，但会先做 capability / market 校验
# 3. 未在能力级配置中出现的 provider 会自动追加到末尾，避免误配导致能力不可用

# 默认顺序：未配置能力专用顺序时使用
PROVIDER_PRIORITY_DEFAULT=longport,jvquant,infoway,coingecko

# get-stock-quote：股票快照行情
PROVIDER_PRIORITY_GET_STOCK_QUOTE=infoway,jvquant,longport,coingecko

# get-market-status：市场状态
PROVIDER_PRIORITY_GET_MARKET_STATUS=longport,jvquant,infoway,coingecko

# get-stock-basic-info：股票基础资料
PROVIDER_PRIORITY_GET_STOCK_BASIC_INFO=infoway,longport,jvquant,coingecko

# get-crypto-basic-info：Crypto 基础资料
PROVIDER_PRIORITY_GET_CRYPTO_BASIC_INFO=coingecko,infoway,longport,jvquant

# stream-stock-quote：股票实时流
PROVIDER_PRIORITY_STREAM_STOCK_QUOTE=longport,jvquant,infoway,coingecko

# stream-crypto-quote：Crypto 实时流
PROVIDER_PRIORITY_STREAM_CRYPTO_QUOTE=infoway,coingecko,longport,jvquant
